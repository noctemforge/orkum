import { ScrollView, Button, VerticalBox, ListView } from "std-widgets.slint";
import { IconButton, Palette } from "util.slint";

export struct HexRow {
    offset: string,
    hex: string,
    ascii: string,
}

export struct FileEntry {
    name: string,
    content: [HexRow],
}

component TabHandle {
    // Supplied 
    in property <string> text;
    in property <bool> active;
    callback clicked();
    callback closed();
    Rectangle {
        min-width: 100px;
        max-width: 200px;
        background: active ? ta-handle.pressed ? Palette.accent-700 : (ta-handle.has-hover ? Palette.accent-600 : Palette.accent-500) : ta-handle.has-hover ? Palette.bg-700 : Palette.bg-900;
        border-radius: 4px;
        ta-handle := TouchArea {
            mouse-cursor: pointer;
            clicked => {
                clicked();
            }
        }

        HorizontalLayout {
            padding: 8px;
            padding-right: 4px;
            alignment: space-between;
            Text {
                text: text;
                color: white;
                vertical-alignment: center;
            }

            IconButton {
                src: @image-url("icons/x-mark.svg");
                clicked => {
                    closed();
                }
            }
        }
    }
}

export component FileTabs {
    // Supplied
    in-out property <int> active-tab;
    in-out property <[FileEntry]> files;
    callback close-file(int);
    VerticalLayout {
        padding: 16px;
        spacing: 8px;

        // TODO: Change with TabWidget when dynamic tabs are supported
        HorizontalLayout {
            alignment: start;
            spacing: 4px;
            for entry[i] in root.files: TabHandle {
                text: entry.name;
                active: root.active-tab == i;
                clicked => {
                    root.active-tab = i
                }
                closed => {
                    root.close-file(i);
                }
            }
        }

        Rectangle {
            background: Palette.bg-800;
            border-radius: 4px;
            VerticalBox {
                ListView {
                    for row in root.files[root.active-tab].content: HorizontalLayout {
                        height: 25px;
                        spacing: 10px;
                        Text {
                            text: row.offset;
                            width: 100px;
                            color: #8b949e;
                            font-family: "Cascadia Mono"; // TODO: Change to linked or bundled
                        }
                        Text {
                            text: row.hex;
                            font-family: "Cascadia Mono"; // TODO: Change to linked or bundled
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }
}
