import { ScrollView, Button, VerticalBox, ListView } from "std-widgets.slint";
import { IconButton, Palette } from "util.slint";

/// Row of editable bytes
export struct ByteData {
    value: string,
    is_modified: bool,
}

/// Row of hex bytes
export struct RowData {
    offset: string,
    bytes: [ByteData],
    ascii: string,
}

/// Representation of the current state of file content
export struct FileEntry {
    name: string,
    modified: bool,
}

component TabHandle {
    // Supplied 
    in property <string> text;
    in property <bool> active;
    callback clicked();
    callback closed();
    Rectangle {
        min-width: 100px;
        max-width: 200px;
        background: active ? ta-handle.pressed ? Palette.accent-700 : (ta-handle.has-hover ? Palette.accent-600 : Palette.accent-500) : ta-handle.has-hover ? Palette.bg-700 : Palette.bg-900;
        border-radius: 4px;
        ta-handle := TouchArea {
            mouse-cursor: pointer;
            clicked => {
                clicked();
            }
        }

        HorizontalLayout {
            padding: 8px;
            padding-right: 4px;
            alignment: space-between;
            Text {
                text: text;
                color: white;
                vertical-alignment: center;
            }

            IconButton {
                src: @image-url("icons/x-mark.svg");
                clicked => {
                    closed();
                }
            }
        }
    }
}

export component FileTabs {
    // Supplied
    in property <[RowData]> hex_rows;
    in-out property <int> active-tab;
    in-out property <[FileEntry]> files;
    callback close-file(int);
    callback byte_edited(int, int, string);
    VerticalLayout {
        padding: 16px;
        spacing: 8px;

        // TODO: Change with TabWidget when dynamic tabs are supported
        HorizontalLayout {
            alignment: start;
            spacing: 4px;
            for entry[i] in root.files: TabHandle {
                text: entry.name;
                active: root.active-tab == i;
                clicked => {
                    root.active-tab = i
                }
                closed => {
                    root.close-file(i);
                }
            }
        }

        Rectangle {
            background: Palette.bg-800;
            border-radius: 4px;
            VerticalBox {
                ListView {
                    for row[r_idx] in root.hex_rows: HorizontalLayout {
                        height: 25px;
                        spacing: 10px;
                        Text {
                            text: row.offset;
                            width: 100px;
                            color: #8b949e;
                            font-family: "Cascadia Mono"; // TODO: Change to linked or bundled
                        }
                        HorizontalLayout {
                            horizontal-stretch: 1;
                            spacing: 4px;
                            for b[b_idx] in row.bytes: Rectangle {
                                width: 24px;
                                background: b.is_modified ? #3e3e10 : transparent;
                                TextInput {
                                    text: b.value;
                                    color: b.is_modified ? #ffcc00 : #c9d1d9;
                                    font-family: "Cascadia Mono"; // TODO: Change to linked or bundled
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                    edited => {
                                        root.byte_edited(r_idx, b_idx, self.text);
                                    }
                                }
                            }
                        }

                        Text {
                            text: row.ascii;
                            width: 150px;
                            font-family: "Cascadia Mono"; // TODO: Change to linked or bundled
                            color: #888;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }
}
