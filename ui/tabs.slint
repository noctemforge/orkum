import { ScrollView, Button, VerticalBox, ListView } from "std-widgets.slint";
import { IconButton, Palette } from "util.slint";

/// Row of editable bytes
export struct ByteData {
    value: string,
    is_modified: bool,
}

/// Row of hex bytes
export struct RowData {
    offset: string,
    bytes: [ByteData],
    ascii: string,
}

/// Representation of the current state of file content
export struct FileEntry {
    name: string,
    modified: bool,
}

export component TabHandle {
    // Supplied 
    in property <string> text;
    in property <bool> active;
    callback on_click();
    callback closed();
    Rectangle {
        min-width: 100px;
        max-width: 200px;
        background: active ? ta-handle.pressed ? Palette.accent-700 : (ta-handle.has-hover ? Palette.accent-600 : Palette.accent-500) : ta-handle.has-hover ? Palette.bg-700 : Palette.bg-900;
        border-radius: 4px;
        ta-handle := TouchArea {
            mouse-cursor: pointer;
            clicked => {
                on_click();
            }
        }

        HorizontalLayout {
            padding: 8px;
            padding-right: 4px;
            alignment: space-between;
            Text {
                text: text;
                color: white;
                vertical-alignment: center;
            }

            IconButton {
                src: @image-url("icons/x-mark.svg");
                clicked => {
                    closed();
                }
            }
        }
    }
}
