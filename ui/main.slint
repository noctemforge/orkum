import { ErrorPopup } from "error.slint";
import { Button, TabWidget, ScrollView } from "std-widgets.slint";

component Landing {
    // In callback
    callback loaded_file;
    update_file := Button {
        text: "Open File";
        clicked => {
            loaded_file();
        }
    }
}

