import { ErrorPopup } from "error.slint";
import { Button, TabWidget, ScrollView } from "std-widgets.slint";
import { FileTabs, FileEntry, RowData } from "tabs.slint";
import { Palette } from "util.slint";

component Landing {
    // Supplied
    callback loaded_file;
    update_file := Button {
        text: "Open File";
        clicked => {
            loaded_file();
        }
    }
}

export component AppWindow inherits Window {
    title: "Orkum";
    preferred-height: 720px;
    preferred-width: 480px;
    background: Palette.bg-950;

    callback open-file-clicked();
    callback switch_file(int);
    callback close-file-clicked(int);
    callback byte_edited(int, int, string);
    callback save_requested();

    in property <[RowData]> hex_rows;
    in property <[FileEntry]> open_files;
    in-out property <int> active-tab: 0;

    if (root.open_files.length == 0): Landing {
        loaded_file => {
            root.open-file-clicked();
        }
    }
    if (root.open_files.length > 0): VerticalLayout {
        padding: 15px;
        spacing: 10px;

        HorizontalLayout {
            spacing: 10px;
            Text {
                text: "Files Open: \{root.open_files.length}";
                vertical-alignment: center;
            }

            Button {
                text: "Open New File";
                clicked => {
                    root.open-file-clicked();
                }
            }
        }

        tabs := FileTabs {
            hex_rows: hex_rows;
            files: open_files;
            close-file(index) => {
                close-file-clicked(index);
            }
            byte_edited(row, byte, val) => {
                byte_edited(row, byte, val)
            }
        }
    }

    callback error_notification <=> error_popup.error_notification;
    error_popup := ErrorPopup {
        height: root.height;
        width: root.width;
    }
}
