import { ErrorPopup } from "error.slint";
import { Button } from "std-widgets.slint";

export component AppWindow inherits Window {
    preferred-height: 720px;
    preferred-width: 1280px;

    in property <[string]> dir_content;

    callback set_new_dir <=> set_new_dir.clicked;
    dir_list := VerticalLayout {
        y: 0;
        spacing: 50px;

        set_new_dir := Button {
            text: "Select Directory";
        }

        Text {
            text: "ORKUM v0.2.0";
        }

        for i in dir_content: Rectangle {
            height: 30px;
            background: blueviolet;
            Text {
                x: 0;
                text: i;
                color: white;
            }
        }
    }

    callback error_notification <=> error_popup.error_notification;
    error_popup := ErrorPopup {
        height: root.height;
        width: root.width;
    }
}
